CREATE TABLE IF NOT EXISTS story_translation (
    story_id INTEGER NOT NULL,
    locale TEXT NOT NULL,
    translation TEXT NOT NULL,
    PRIMARY KEY (story_id, locale),
    FOREIGN KEY (story_id) REFERENCES story(id) ON DELETE CASCADE
);

getStoryTranslation:
SELECT translation FROM story_translation
WHERE story_id = :storyId AND locale = :locale;

getAllStoryTranslations:
SELECT * FROM story_translation;
