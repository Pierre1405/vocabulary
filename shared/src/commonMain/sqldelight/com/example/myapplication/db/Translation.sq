CREATE TABLE IF NOT EXISTS translation (
    sentence_id INTEGER NOT NULL,
    locale TEXT NOT NULL,
    translation TEXT NOT NULL,
    PRIMARY KEY (sentence_id, locale),
    FOREIGN KEY (sentence_id) REFERENCES sentence(id) ON DELETE CASCADE
);

getTranslationsForStory:
SELECT * FROM translation
WHERE sentence_id IN (SELECT id FROM sentence WHERE story_id = :storyId);

getTranslationsByPhraseId:
SELECT * FROM translation WHERE sentence_id = :phraseId;
